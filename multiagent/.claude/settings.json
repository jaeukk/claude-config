{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-fable-5",
  "enabledMcpjsonServers": ["codex"],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit|Bash|Task|mcp__codex__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PROJECT_DIR}/engine/adapters/claude_pretool_runner.js"]
          }
        ]
      }
    ]
  }
}
